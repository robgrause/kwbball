block content
	div.settingsmenu(id='divSettingsMenu')
		div.settingsmenuuser
			i.settingsmenuusericon(class="bi bi-person")
			label(id='divSettingsUserId') Keaton Weaver
		div.settingsmenutitlelabel
			label ACCOUNT
		div.settingsmenucmd(id='cmdSettingsProfile')
			label.settingsmenulabel(id='cmdSettingsProfile') Profile
			i.settingsmenuicon(class="bi bi-chevron-right" id='cmdSettingsProfile')
		div.settingsmenutitlelabel
			label APP SETTINGS
		div.settingsmenucmd(id='cmdSettingsPlayers')
			label.settingsmenulabel(id='cmdSettingsPlayers') Players
			i.settingsmenuicon(class="bi bi-chevron-right" id='cmdSettingsPlayers')
		div.settingsmenucmd(id='cmdSettingsCoaches')
			label.settingsmenulabel(id='cmdSettingsCoaches') Coaches
			i.settingsmenuicon(class="bi bi-chevron-right" id='cmdSettingsCoaches')
		div.settingsmenucmd(id='cmdSettingsLists')
			label.settingsmenulabel(id='cmdSettingsLists') Lists
			i.settingsmenuicon(class="bi bi-chevron-right" id='cmdSettingsLists')
		div.settingsmenucmd(id='cmdSettingsSystem')
			label.settingsmenulabel(id='cmdSettingsSystem') System
			i.settingsmenuicon(class="bi bi-chevron-right" id='cmdSettingsSystem')
	div(id='divSettingsLists')
		div.listtype(id='divListTypeId')
			div.listtypedown(id='divListTypeDownId')
			div.listtypeselect(id='divListTypeSelectId')
			div.listtypeup(id='divListTypeUpId')
		div.row
			div.col-12
				table.data(id="tblNameList",
					class="display nowrap table-striped table-bordered table-sm")
					thead
					tbody
	div(id='divSettingsCoaches')
		div.row.mt-2
			label.settingstablelabel Coaches
		div.row
			div.col-12
				table.data(id="tblCoachesList",
					class="display nowrap table-striped table-bordered table-sm")
					thead
					tbody
	div(id='divSettingsPlayers')
		div.row.mt-2
			label.settingstablelabel Players
		div.row.mt-2
			label.settingstablelabel Find By:
		div.playertype(id='divPlayerTypeId')
			div.playertypedown(id='divPlayerTypeDownId')
			div.playertypeselect(id='divPlayerTypeSelectId')
			div.playertypeup(id='divPlayerTypeUpId')
		div.playertype(id='divPlayerSearchId')
			div.playersearchfield(class="form-group form-floating")
				input(class='form-control',type="text", onclick="this.select()" 
					id='inputPlayerPropertyListId', 
					list='datalistPlayerPropertyListId', placeholder="")
				datalist(id='datalistPlayerPropertyListId')
			div.playerfind(id='divPlayerFindId')
		div.row
			div.col-12
				table.data(id="tblPlayersList",
					class="display nowrap table-striped table-bordered table-sm")
					thead
					tbody
	div(id="divSettingsSystem")
		div.row.mt-2
			div.col-md-2
				div(class="form-group form-floating")
					input(class="form-control",type="number" id="f_system_client_refreshrate", placeholder="rate" min="10" max="300" value="20")
					label(for="f_system_client_refreshrate") Client Refresh Rate
			div.col-md-10
				div.btn-group.text-end
					button.aGPT(id="btnSystemDefaults", title='save') RESET DEFAULTS
					button.aGPT(id="btnSystemCleanup", title='save') SYSTEM CLEANUP
		div.row.mt-2
			hr
		div.row.mt-2.mb-2
			div.col-md-12.text-start
				b Background
		div.row
			div.col-md-5
				div(class="form-group form-floating")
					input(class='form-control',type="text", disabled id="f_system_original_backgroundimage", placeholder="")
					label(for="f_system_original_backgroundimage") Image
			div.col-md-5
				div(class="form-group form-floating")
					div(class="custom-file")
						label(id="",class="form-label" for="f_system_background_image_select")
