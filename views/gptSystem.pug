			div.col-md-2
				div.btn-group
					button.aGPT(id="btnSystemBackgroundImageUpload", title='upload') UPLOAD
		div.row
			div.col-md-3
				div(class="form-group form-floating")
					input(class='form-control',type="range", min='0' max='100' 
						id="f_system_opacity_backgroundimage", placeholder=""
						oninput="opacity_backgroundimage_value.value = this.value")
					label(for="f_system_opacity_backgroundimage") Opacity
			div.col-md-2
				div(class="form-group form-floating")
					input.text-center(id="opacity_backgroundimage_value" class='form-control' readonly)
					label(for="opacity_backgroundimage_value") Opacity
			div.col-md-3
				div(class="form-group form-floating")
					input(class='form-control',type="color", id="f_system_color_backgroundimage", placeholder="")
					label(for="f_system_color_backgroundimage") Color
